---
import Base from '../layouts/Base.astro';
import { profile } from '../data/profile';
import '../styles/noir.css';
---

<Base title="DF Wu — Noir">
  <div class="wrap">
    <nav class="nav">
      <span class="nav-name">DF Wu</span>
      <div class="nav-links">
        <a href={profile.links.github} target="_blank" rel="noopener">GitHub</a>
        <a href={profile.links.linkedin} target="_blank" rel="noopener">LinkedIn</a>
        <a href={profile.links.website} target="_blank" rel="noopener">Website</a>
        <a href={profile.links.mastodon} target="_blank" rel="noopener">Mastodon</a>
      </div>
    </nav>

    <section class="hero">
      <p class="hero-role">{profile.title}</p>
      <h1>{profile.name}</h1>
      <p class="hero-sub">{profile.tagline}</p>
    </section>

    <section class="section">
      <p class="section-label">About</p>
      {profile.about.map((text) => <p>{text}</p>)}
    </section>

    <section class="section">
      <p class="section-label">Signal</p>
      <div class="stats">
        <div class="stat"><div class="stat-value">{profile.stats.publicRepos}</div><div class="stat-label">Public Repos</div></div>
        <div class="stat"><div class="stat-value">{profile.stats.ownedRepos}</div><div class="stat-label">Owned</div></div>
        <div class="stat"><div class="stat-value">{profile.stats.yearlyContributions}</div><div class="stat-label">Contributions/yr</div></div>
        <div class="stat"><div class="stat-value">{profile.stats.yearlyCommits}</div><div class="stat-label">Commits/yr</div></div>
        <div class="stat"><div class="stat-value">{profile.stats.mergedPRs}</div><div class="stat-label">Merged PRs</div></div>
        <div class="stat"><div class="stat-value">{profile.stats.externalPRs}</div><div class="stat-label">External PRs</div></div>
      </div>
    </section>

    <section class="section">
      <p class="section-label">Stack</p>
      <h2>Languages</h2>
      <div class="skills-grid" style="margin-bottom:1rem">
        {profile.skills.languages.map((s) => <span class="skill-tag">{s}</span>)}
      </div>
      <h2>Infrastructure</h2>
      <div class="skills-grid">
        {[...profile.skills.frameworks, ...profile.skills.infrastructure].map((s) => <span class="skill-tag">{s}</span>)}
      </div>
    </section>

    <section class="section">
      <p class="section-label">Selected Work</p>
      <div class="projects">
        {profile.projects.map((p) => (
          <a class="project" href={p.url} target="_blank" rel="noopener">
            <span class="project-stack">{p.stack}</span>
            <h3>{p.name}</h3>
            <p>{p.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="section">
      <p class="section-label">Open Source</p>
      <div class="contribs">
        {profile.contributions.map((c) => (
          <a class="contrib" href={c.url} target="_blank" rel="noopener">
            <span class="contrib-type">{c.type}</span>
            <span>{c.description}</span>
            <span class="contrib-repo">{c.repo} {c.pr}</span>
          </a>
        ))}
      </div>
    </section>

    <section class="section">
      <p class="section-label">Role Fit</p>
      <div class="roles">
        {profile.roles.map((r) => (
          <div class="role">
            <h3>{r.title}</h3>
            <p>{r.why}</p>
            <div class="role-evidence">{r.evidence}</div>
          </div>
        ))}
      </div>
    </section>

    <section class="section">
      <p class="section-label">First 90 Days</p>
      <div class="ramp">
        {profile.rampUp.map((r) => (
          <div class="ramp-item">
            <span class="ramp-phase">{r.phase}</span>
            <span class="ramp-focus">{r.focus}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="contact">
      <h2>Let's connect.</h2>
      <p>Teams that value stable systems over fast demos — I'd like to hear about the role.</p>
      <div class="contact-links">
        <a class="primary" href={profile.links.linkedin} target="_blank" rel="noopener">LinkedIn</a>
        <a href={profile.links.resume} target="_blank" rel="noopener">Resume</a>
        <a href={profile.links.github} target="_blank" rel="noopener">GitHub</a>
        <a href={profile.links.mastodon} target="_blank" rel="noopener">Mastodon</a>
      </div>
    </section>

    <footer class="footer">
      <p>&copy; {new Date().getFullYear()} DF Wu &middot; Taipei, Taiwan</p>
    </footer>
  </div>
</Base>
