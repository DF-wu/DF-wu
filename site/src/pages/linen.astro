---
import Base from '../layouts/Base.astro';
import { profile } from '../data/profile';
import '../styles/linen.css';
---

<Base title="DF Wu — Linen">
  <div class="wrap">
    <nav class="nav">
      <span class="nav-name">DF Wu</span>
      <div class="nav-links">
        <a href={profile.links.github} target="_blank" rel="noopener">GitHub</a>
        <a href={profile.links.linkedin} target="_blank" rel="noopener">LinkedIn</a>
        <a href={profile.links.website} target="_blank" rel="noopener">Website</a>
      </div>
    </nav>

    <section class="hero">
      <p class="hero-role">{profile.title} &middot; {profile.location}</p>
      <h1>Systems designed for clarity, built for the team that comes after me.</h1>
      <p class="hero-sub">{profile.tagline}</p>
    </section>

    <section class="section">
      <p class="section-label">About</p>
      {profile.about.map((text) => <p>{text}</p>)}
    </section>

    <section class="section">
      <p class="section-label">At a Glance</p>
      <div class="stats">
        <div class="stat"><div class="stat-value">{profile.stats.publicRepos}</div><div class="stat-label">Repositories</div></div>
        <div class="stat"><div class="stat-value">{profile.stats.yearlyContributions}</div><div class="stat-label">Contributions</div></div>
        <div class="stat"><div class="stat-value">{profile.stats.yearlyCommits}</div><div class="stat-label">Commits</div></div>
        <div class="stat"><div class="stat-value">{profile.stats.mergedPRs}</div><div class="stat-label">Merged PRs</div></div>
      </div>
    </section>

    <section class="section">
      <p class="section-label">Expertise</p>
      <div class="skills-grid" style="margin-bottom:1rem">
        {profile.skills.languages.map((s) => <span class="skill-tag">{s}</span>)}
      </div>
      <div class="skills-grid">
        {[...profile.skills.frameworks, ...profile.skills.infrastructure].map((s) => <span class="skill-tag">{s}</span>)}
      </div>
    </section>

    <section class="section">
      <p class="section-label">Selected Work</p>
      <div class="projects">
        {profile.projects.map((p) => (
          <a class="project" href={p.url} target="_blank" rel="noopener">
            <span class="project-stack">{p.stack}</span>
            <h3>{p.name}</h3>
            <p>{p.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="section">
      <p class="section-label">Open Source</p>
      <div class="contribs">
        {profile.contributions.map((c) => (
          <a class="contrib" href={c.url} target="_blank" rel="noopener">
            <span>{c.description}</span>
            <span class="contrib-type">{c.type}</span>
          </a>
        ))}
      </div>
    </section>

    <section class="section">
      <p class="section-label">Where I Fit</p>
      <div class="roles">
        {profile.roles.map((r) => (
          <div class="role">
            <h3>{r.title}</h3>
            <p>{r.why}</p>
            <div class="role-evidence">{r.evidence}</div>
          </div>
        ))}
      </div>
    </section>

    <section class="section">
      <p class="section-label">How I Join Teams</p>
      <div class="ramp">
        {profile.rampUp.map((r) => (
          <div class="ramp-item">
            <span class="ramp-phase">{r.phase}</span>
            <span class="ramp-focus">{r.focus}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="contact">
      <h2>Interested in working together?</h2>
      <p>I'm best suited for teams that value maintainability, stability, and calm execution.</p>
      <div class="contact-links">
        <a class="primary" href={profile.links.linkedin} target="_blank" rel="noopener">Connect on LinkedIn</a>
        <a href={profile.links.resume} target="_blank" rel="noopener">Resume</a>
        <a href={profile.links.github} target="_blank" rel="noopener">GitHub</a>
      </div>
    </section>

    <footer class="footer">
      <p>&copy; {new Date().getFullYear()} DF Wu</p>
    </footer>
  </div>
</Base>
