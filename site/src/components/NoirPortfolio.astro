---
import { profile } from '../data/profile';

const proofStats = [
  { value: profile.stats.publicRepos, label: 'public repos' },
  { value: profile.stats.yearlyContributions, label: 'contributions / year' },
  { value: profile.stats.ieeepapers, label: 'IEEE papers' },
  { value: profile.stats.mergedPRs, label: 'merged PRs' },
];

const stackGroups = [
  { label: 'Languages', items: profile.skills.languages },
  { label: 'Runtime & Web', items: profile.skills.frameworks },
  { label: 'Infrastructure', items: profile.skills.infrastructure },
  { label: 'Data & Messaging', items: profile.skills.data },
  { label: 'Engineering Practices', items: profile.skills.practices },
];

const operatingSignals = [
  {
    title: 'Research-grade backend design',
    body: 'CCTS turns event-driven behavior into contract checks and state-model validation, tying thesis work to production-minded reliability.',
    proof: 'APSEC 2022 · TCSE Best Chinese Paper',
  },
  {
    title: 'Deployment-aware ownership',
    body: 'Home-lab services, Docker composition, server automation, and day-two operations shape how I design backend systems.',
    proof: 'myServices · iDRACFanSpeedControl',
  },
  {
    title: 'Open-source collaboration',
    body: 'I tend to contribute where correctness, integrations, localization, and maintainability unblock real users.',
    proof: '13 external merged PRs',
  },
];
---

<div class="site-shell">
  <nav class="nav" aria-label="Primary">
    <a class="nav-brand" href="#top" aria-label="DF Wu home">
      <span class="brand-mark">DF</span>
      <span>
        <strong>{profile.fullName}</strong>
        <small>{profile.location}</small>
      </span>
    </a>
    <div class="nav-links">
      <a href="#evidence">Evidence</a>
      <a href="#work">Work</a>
      <a href="#stack">Stack</a>
      <a href="#contact">Contact</a>
    </div>
  </nav>

  <main id="top">
    <section class="hero section-band" aria-labelledby="hero-title">
      <div class="hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">{profile.title} / {profile.location}</p>
          <h1 id="hero-title">{profile.fullName}</h1>
          <p class="hero-lede">{profile.tagline}</p>
          <p class="hero-note">
            I build systems with readable architecture, measurable reliability, and enough operational discipline to survive the handoff.
          </p>
          <div class="hero-actions" aria-label="Primary links">
            <a class="button button-primary" href={profile.links.linkedin} target="_blank" rel="noopener">Connect</a>
            <a class="button" href={profile.links.resume} target="_blank" rel="noopener">Resume</a>
            <a class="button" href={profile.links.github} target="_blank" rel="noopener">GitHub</a>
          </div>
        </div>

        <aside class="identity-panel" aria-label="Profile summary">
          <div class="avatar-frame">
            <img src="https://github.com/DF-wu.png?size=320" alt="Portrait avatar of ChuFei Wu" width="320" height="320" loading="eager" />
          </div>
          <div class="identity-copy">
            <p class="panel-label">Current signal</p>
            <h2>Backend systems, platform habits, research evidence.</h2>
            <p>{profile.motto}</p>
          </div>
          <div class="runtime-grid" aria-label="Engineering focus">
            <span>contracts</span>
            <strong>verified</strong>
            <span>deploys</span>
            <strong>observable</strong>
            <span>handoff</span>
            <strong>readable</strong>
          </div>
        </aside>
      </div>

      <div class="proof-strip" aria-label="Profile metrics">
        {proofStats.map((stat) => (
          <div class="proof-item">
            <strong>{stat.value}</strong>
            <span>{stat.label}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="section-band intro-grid" id="evidence" aria-labelledby="evidence-title">
      <div class="section-heading">
        <p class="eyebrow">Engineering dossier</p>
        <h2 id="evidence-title">Reliability is the through-line.</h2>
      </div>
      <div class="intro-copy">
        {profile.about.map((text) => <p>{text}</p>)}
      </div>
    </section>

    <section class="section-band signal-grid" aria-label="Operating evidence">
      {operatingSignals.map((signal) => (
        <article class="signal-card">
          <span class="signal-index">{signal.proof}</span>
          <h3>{signal.title}</h3>
          <p>{signal.body}</p>
        </article>
      ))}
    </section>

    <section class="section-band split-section" aria-labelledby="research-title">
      <div class="section-heading sticky-heading">
        <p class="eyebrow">Published research</p>
        <h2 id="research-title">Event-driven systems, authorization, and testability.</h2>
        <p>
          Two IEEE publications and three domestic conference papers connect my backend work to formal software engineering research.
        </p>
      </div>
      <div class="research-list">
        {profile.publications.map((paper) => (
          <a class="paper-card" href={paper.url} target="_blank" rel="noopener">
            <div>
              <span class="paper-meta">{paper.publisher} · {paper.venue} · {paper.year}</span>
              <h3>{paper.title}</h3>
              <p>{paper.abstract}</p>
            </div>
            <span class="paper-role">{paper.role}</span>
          </a>
        ))}
        <div class="domestic-stack" aria-label="Domestic publications">
          {profile.domesticPublications.map((paper) => (
            <article class="compact-paper">
              <span>{paper.year}</span>
              <div>
                <h3>{paper.title}</h3>
                <p>{paper.titleEn}</p>
                <small>{paper.venue} · {paper.location}</small>
                {paper.award && <strong>{paper.award}</strong>}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-band" id="work" aria-labelledby="work-title">
      <div class="section-heading wide-heading">
        <p class="eyebrow">Selected work</p>
        <h2 id="work-title">Projects that show ownership under real constraints.</h2>
      </div>
      <div class="project-grid">
        {profile.projects.map((project) => (
          <a class="project-card" href={project.url} target="_blank" rel="noopener">
            <span class="project-stack">{project.stack}</span>
            <h3>{project.name}</h3>
            <p>{project.description}</p>
            {project.highlight && <strong>{project.highlight}</strong>}
          </a>
        ))}
      </div>
    </section>

    <section class="section-band split-section" id="stack" aria-labelledby="stack-title">
      <div class="section-heading sticky-heading">
        <p class="eyebrow">Technical surface</p>
        <h2 id="stack-title">Backend depth with platform instincts.</h2>
        <p>
          I am strongest where code quality, runtime behavior, deployment pressure, and team handoff all meet.
        </p>
      </div>
      <div class="stack-board">
        {stackGroups.map((group) => (
          <article class="stack-group">
            <h3>{group.label}</h3>
            <div class="tag-cloud">
              {group.items.map((item) => <span>{item}</span>)}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section-band split-section" aria-labelledby="oss-title">
      <div class="section-heading sticky-heading">
        <p class="eyebrow">Collaboration trail</p>
        <h2 id="oss-title">Small PRs, clear intent, durable value.</h2>
      </div>
      <div class="contribution-list">
        {profile.contributions.map((item) => (
          <a class="contribution-row" href={item.url} target="_blank" rel="noopener">
            <span>{item.type}</span>
            <strong>{item.description}</strong>
            <small>{item.repo} {item.pr}</small>
          </a>
        ))}
      </div>
    </section>

    <section class="section-band role-lab" aria-labelledby="roles-title">
      <div class="section-heading wide-heading">
        <p class="eyebrow">Hiring fit</p>
        <h2 id="roles-title">Where I can create leverage quickly.</h2>
      </div>
      <div class="role-grid">
        {profile.roles.map((role) => (
          <article class="role-card">
            <span>{role.evidence}</span>
            <h3>{role.title}</h3>
            <p>{role.why}</p>
          </article>
        ))}
      </div>
      <div class="ramp-track" aria-label="First 90 days plan">
        {profile.rampUp.map((item) => (
          <article>
            <strong>{item.phase}</strong>
            <p>{item.focus}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section-band beyond-grid" aria-labelledby="beyond-title">
      <div class="section-heading">
        <p class="eyebrow">Beyond code</p>
        <h2 id="beyond-title">Systems thinking does not stop at the repo.</h2>
      </div>
      <div class="tag-cloud large-tags">
        {profile.interests.map((interest) => <span>{interest}</span>)}
      </div>
    </section>

    <section class="contact-panel" id="contact" aria-labelledby="contact-title">
      <p class="eyebrow">Contact</p>
      <h2 id="contact-title">Looking for backend execution with production memory?</h2>
      <p>Teams building reliable services, platform infrastructure, or research-backed systems are the best fit.</p>
      <div class="contact-links">
        <a class="button button-primary" href={profile.links.email}>{profile.links.emailAddress}</a>
        <a class="button" href={profile.links.linkedin} target="_blank" rel="noopener">LinkedIn</a>
        <a class="button" href={profile.links.paper} target="_blank" rel="noopener">IEEE Paper</a>
        <a class="button" href={profile.links.mastodon} target="_blank" rel="noopener">Mastodon</a>
      </div>
    </section>
  </main>

  <footer class="footer">
    <span>{profile.nameZh} · {profile.fullName}</span>
    <span>{new Date().getFullYear()} · {profile.location}</span>
  </footer>
</div>
