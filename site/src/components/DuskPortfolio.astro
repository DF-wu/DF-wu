---
import { profile } from '../data/profile';
---

<div class="wrap">
  <nav class="nav">
    <span class="nav-name">DF Wu</span>
    <div class="nav-links">
      <a href={profile.links.github} target="_blank" rel="noopener">GitHub</a>
      <a href={profile.links.linkedin} target="_blank" rel="noopener">LinkedIn</a>
      <a href={profile.links.paper} target="_blank" rel="noopener">Paper</a>
      <a href={profile.links.mastodon} target="_blank" rel="noopener">Mastodon</a>
    </div>
  </nav>

  <section class="hero">
    <p class="hero-role">{profile.title} &middot; {profile.location}</p>
    <h1>{profile.name}</h1>
    <p class="hero-sub">{profile.tagline}</p>
    <div class="hero-actions">
      <a class="primary" href={profile.links.linkedin} target="_blank" rel="noopener">Connect</a>
      <a class="secondary" href={profile.links.paper} target="_blank" rel="noopener">Read Paper</a>
    </div>
  </section>

  <div class="divider"></div>

  <section class="section">
    <p class="section-label">About</p>
    {profile.about.map((text) => <p>{text}</p>)}
  </section>

  <div class="divider"></div>

  <section class="section">
    <p class="section-label">Education</p>
    <div class="role">
      <h3>{profile.education.degree}</h3>
      <p>{profile.education.school} &middot; Graduated {profile.education.graduated}</p>
      <div class="role-evidence">{profile.education.lab} &middot; Advisor: {profile.education.advisor}</div>
      <p style="margin-top:0.5rem">Thesis focus: {profile.education.focus}</p>
    </div>
  </section>

  <div class="divider"></div>

  <section class="section">
    <p class="section-label">Publications · IEEE</p>
    <div style="display:grid;gap:1rem">
      {profile.publications.map((p) => (
        <a class="project" href={p.url} target="_blank" rel="noopener" style="display:block">
          <span class="project-stack">{p.publisher} &middot; {p.venue} &middot; {p.year}{p.location ? ` · ${p.location}` : ''}</span>
          <h3>{p.title}</h3>
          <p style="margin-bottom:0.5rem;opacity:0.85;font-size:0.9rem">{p.authors.join(', ')}</p>
          <p style="font-size:0.88rem;margin-bottom:0.4rem">{p.abstract}</p>
          <p style="font-size:0.78rem;color:var(--accent);font-weight:700">{p.role}</p>
        </a>
      ))}
    </div>
  </section>

  <div class="divider"></div>

  <section class="section">
    <p class="section-label">Conference Papers · Domestic</p>
    <div style="display:grid;gap:0.75rem">
      {profile.domesticPublications.map((p) => (
        <div style="padding:1rem;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);display:flex;flex-direction:column;gap:0.35rem">
          <strong style="font-size:0.98rem">{p.title}</strong>
          <span style="color:var(--muted);font-size:0.82rem;font-style:italic">{p.titleEn}</span>
          <span style="color:var(--muted);font-size:0.8rem">{p.authors.join('、')}</span>
          <span style="color:var(--accent);font-size:0.78rem">{p.venue} &middot; {p.location} &middot; {p.year}</span>
          {p.award && <span style="font-size:0.78rem;color:var(--accent2);font-weight:700">🏆 {p.award}</span>}
        </div>
      ))}
    </div>
  </section>

  <div class="divider"></div>

  <section class="section">
    <p class="section-label">Awards</p>
    {profile.awards.map((a) => (
      <div class="role" style="background:linear-gradient(135deg, rgba(94,234,212,0.1), rgba(192,132,252,0.08))">
        <h3>🏆 {a.title}</h3>
        <p>{a.context}</p>
        <div class="role-evidence">{a.year}</div>
      </div>
    ))}
  </section>

  <div class="divider"></div>

  <section class="section">
    <p class="section-label">Research Highlights</p>
    <ul style="padding-left:1.2rem;color:var(--muted);line-height:1.75">
      {profile.researchHighlights.map((h) => <li style="margin-bottom:0.5rem">{h}</li>)}
    </ul>
  </section>

  <div class="divider"></div>

  <section class="section">
    <p class="section-label">Metrics</p>
    <div class="stats">
      <div class="stat"><div class="stat-value">{profile.stats.publicRepos}</div><div class="stat-label">Repositories</div></div>
      <div class="stat"><div class="stat-value">{profile.stats.yearlyContributions}</div><div class="stat-label">Contributions/yr</div></div>
      <div class="stat"><div class="stat-value">{profile.stats.ieeepapers}</div><div class="stat-label">IEEE Papers</div></div>
      <div class="stat"><div class="stat-value">{profile.stats.mergedPRs}</div><div class="stat-label">Merged PRs</div></div>
    </div>
  </section>

  <div class="divider"></div>

  <section class="section">
    <p class="section-label">Stack</p>
    <div class="skills-grid" style="margin-bottom:0.75rem">
      {profile.skills.languages.map((s) => <span class="skill-tag">{s}</span>)}
    </div>
    <div class="skills-grid" style="margin-bottom:0.75rem">
      {[...profile.skills.frameworks, ...profile.skills.infrastructure, ...profile.skills.data].map((s) => <span class="skill-tag">{s}</span>)}
    </div>
    <div class="skills-grid">
      {profile.skills.practices.map((s) => <span class="skill-tag">{s}</span>)}
    </div>
  </section>

  <div class="divider"></div>

  <section class="section">
    <p class="section-label">Projects</p>
    <div class="projects">
      {profile.projects.map((p) => (
        <a class="project" href={p.url} target="_blank" rel="noopener">
          <span class="project-stack">{p.stack}</span>
          <h3>{p.name}</h3>
          <p>{p.description}</p>
        </a>
      ))}
    </div>
  </section>

  <div class="divider"></div>

  <section class="section">
    <p class="section-label">Experience</p>
    <div class="roles">
      {profile.experience.map((e) => (
        <div class="role">
          <h3>{e.role} &middot; {e.org}</h3>
          <p>{e.summary}</p>
          <div class="role-evidence">{e.period}</div>
        </div>
      ))}
    </div>
  </section>

  <div class="divider"></div>

  <section class="section">
    <p class="section-label">Open Source</p>
    <div class="contribs">
      {profile.contributions.map((c) => (
        <a class="contrib" href={c.url} target="_blank" rel="noopener">
          <span class="contrib-type">{c.type}</span>
          <span>{c.description}</span>
          <span class="contrib-repo">{c.repo} {c.pr}</span>
        </a>
      ))}
    </div>
  </section>

  <div class="divider"></div>

  <section class="section">
    <p class="section-label">Role Fit</p>
    <div class="roles">
      {profile.roles.map((r) => (
        <div class="role">
          <h3>{r.title}</h3>
          <p>{r.why}</p>
          <div class="role-evidence">{r.evidence}</div>
        </div>
      ))}
    </div>
  </section>

  <div class="divider"></div>

  <section class="section">
    <p class="section-label">First 90 Days</p>
    <div class="ramp">
      {profile.rampUp.map((r) => (
        <div class="ramp-item">
          <span class="ramp-phase">{r.phase}</span>
          <span class="ramp-focus">{r.focus}</span>
        </div>
      ))}
    </div>
  </section>

  <div class="divider"></div>

  <section class="section">
    <p class="section-label">Beyond Code</p>
    <div class="skills-grid">
      {profile.interests.map((i) => <span class="skill-tag">{i}</span>)}
    </div>
  </section>

  <section class="contact">
    <h2>Looking for reliable execution?</h2>
    <p>I build systems that stay standing after the demo. Let's connect.</p>
    <div class="contact-links">
      <a class="primary" href={profile.links.linkedin} target="_blank" rel="noopener">LinkedIn</a>
      <a href={profile.links.email}>{profile.links.emailAddress}</a>
      <a href={profile.links.resume} target="_blank" rel="noopener">Resume</a>
      <a href={profile.links.github} target="_blank" rel="noopener">GitHub</a>
    </div>
  </section>

  <footer class="footer">
    <p>&copy; {new Date().getFullYear()} {profile.fullName} &middot; {profile.location}</p>
  </footer>
</div>
